# Kontrol Backend — Environment Variables
# Copy to .env and fill in. Never commit .env.
# MINIMUM TO RUN: CLAUDE_API_KEY + SUPABASE_* (three vars)

# ── Claude AI (REQUIRED for generation) ──────────────────
# https://console.anthropic.com/account/keys
CLAUDE_API_KEY=your_claude_api_key_here

# ── Supabase PostgreSQL (REQUIRED) ───────────────────────
# Dashboard -> Project Settings -> Database -> Connection string (URI)
SUPABASE_DB_URL=jdbc:postgresql://db.YOUR_REF.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_supabase_db_password

# ── CORS / Frontend URL ───────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Instagram & Facebook (Meta Graph API) ────────────────
# https://developers.facebook.com/apps/ -> Create App
META_APP_ID=get_from_meta_developer_portal
META_APP_SECRET=get_from_meta_developer_portal

# ── TikTok ───────────────────────────────────────────────
# https://developers.tiktok.com/apps/ — requires developer approval
TIKTOK_CLIENT_KEY=get_from_tiktok_developer_portal
TIKTOK_CLIENT_SECRET=get_from_tiktok_developer_portal

# ── LinkedIn ─────────────────────────────────────────────
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=get_from_linkedin_developer_portal
LINKEDIN_CLIENT_SECRET=get_from_linkedin_developer_portal

# ── Reddit ───────────────────────────────────────────────
# https://www.reddit.com/prefs/apps -> Create app (type: script)
REDDIT_CLIENT_ID=get_from_reddit_app_preferences
REDDIT_CLIENT_SECRET=get_from_reddit_app_preferences
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ── X / Twitter ──────────────────────────────────────────
# https://developer.twitter.com/en/portal/dashboard — Elevated access required
TWITTER_API_KEY=get_from_developer_twitter_com
TWITTER_API_SECRET=get_from_developer_twitter_com
TWITTER_ACCESS_TOKEN=get_from_developer_twitter_com
TWITTER_ACCESS_SECRET=get_from_developer_twitter_com

# ── Facebook Page ─────────────────────────────────────────
# Same Meta app as Instagram — pages_manage_posts permission
FACEBOOK_PAGE_ACCESS_TOKEN=get_from_meta_developer_portal
FACEBOOK_PAGE_ID=your_facebook_page_id

# ── YouTube ───────────────────────────────────────────────
# https://console.cloud.google.com -> YouTube Data API v3
# Refresh token via https://developers.google.com/oauthplayground
YOUTUBE_CLIENT_ID=get_from_google_cloud_console
YOUTUBE_CLIENT_SECRET=get_from_google_cloud_console
YOUTUBE_REFRESH_TOKEN=get_from_oauth_playground
YOUTUBE_API_KEY=get_from_google_cloud_console

# ── Steam ─────────────────────────────────────────────────
# https://partner.steamgames.com — requires partner account
STEAM_PARTNER_KEY=get_from_steamworks_partner_portal
STEAM_APP_ID=your_game_steam_app_id

# ── itch.io ───────────────────────────────────────────────
# https://itch.io/user/settings/api-keys
ITCHIO_API_KEY=get_from_itch_io_settings
ITCHIO_GAME_ID=your_game_id_on_itchio

# ── Game Jolt ─────────────────────────────────────────────
# https://gamejolt.com/dashboard/games -> API Settings
GAMEJOLT_GAME_ID=your_game_id
GAMEJOLT_API_KEY=get_from_gamejolt_dashboard

# ── PWA Push Notifications (optional) ────────────────────
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
